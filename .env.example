# DeepSeek API Key（必填）
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# TikHub API Key（留空则使用 Mock 数据）
TIKHUB_API_KEY=MOCK

# Amazon 数据 API Key（留空则使用 Mock 数据）
# 使用 SerpApi：https://serpapi.com
AMAZON_API_KEY=MOCK

# 扫描参数
TOTAL_BUDGET=5000
CATEGORY=家居用品
KEYWORDS=portable blender,air fryer accessories,posture corrector
